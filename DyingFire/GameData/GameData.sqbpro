-- 4. Insert all 5 GameItems from your screenshot
INSERT INTO &quot;GameItems&quot; (&quot;ID&quot;, &quot;Name&quot;, &quot;Description&quot;, &quot;ImagePath&quot;, &quot;Type&quot;, &quot;Lore&quot;, &quot;ParentLocationID&quot;, &quot;ParentInteractableID&quot;) VALUES 
(1, 'Rusty Key', 'An old iron key. Might open a door nearby.', NULL, 0, NULL, NULL, 1),
(2, 'Crumpled Note', 'A hastily written note.', NULL, 3, 'If anyone finds this, do not make a sound.', NULL, 3),
(3, 'Investigator Journal', 'Torn page from a journal.', NULL, 3, 'The entity feeds on fear and tracks noise.', NULL, 4),
(4, 'Heavy Wrench', 'A solid iron wrench.', NULL, 1, 'Covered in old, dried blood.', NULL, 5),
(5, 'Spirit Box', 'A modified radio used to communicate with the dead.', NULL, 3, 'It emits a low hum.', NULL, 6);</sql><current_tab id="0"/></tab_sql></sqlb_project>
