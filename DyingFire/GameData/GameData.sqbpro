INSERT INTO &quot;Interactables&quot; (&quot;ID&quot;, &quot;Name&quot;, &quot;X&quot;, &quot;Y&quot;, &quot;Width&quot;, &quot;Height&quot;, &quot;IsLocked&quot;, &quot;RequiredItem&quot;, &quot;LockedMessage&quot;, &quot;TargetLocationID&quot;, &quot;ParentLocationID&quot;, &quot;CanHideInside&quot;) VALUES 
