DELETE FROM &quot;Interactables&quot;;
DELETE FROM &quot;GameItems&quot;;

-- 2. Insert all 15 Locations from your screenshot
INSERT INTO &quot;Locations&quot; (&quot;ID&quot;, &quot;Name&quot;, &quot;ImagePath&quot;, &quot;Description&quot;, &quot;NoiseLevel&quot;, &quot;IsDark&quot;, &quot;NorthID&quot;, &quot;EastID&quot;, &quot;SouthID&quot;, &quot;WestID&quot;) VALUES 
(1, 'Cell', '/Assets/Images/Cell.png', 'A cold, damp cell. This is where you woke up.', 0, 0, 2, -1, -1, -1),
(2, 'Hallway', '/Assets/Images/hallway.png', 'A long, dreary hallway.', 0, 0, 4, -1, 1, 13),
(3, 'Stairs', '/Assets/Images/Stairs.png', 'A set of stairs leading up into the darkness.', 0, 0, 5, -1, 14, 2),
(4, 'Room 2', '/Assets/Images/room2.png', 'An abandoned room.', 0, 0, -1, -1, 2, -1),
(5, 'Fella on the Stairs', '/Assets/Images/fellaOnTheStairs.png', 'There is someone... or something... here.', 0, 0, -1, -1, 6, -1),
(6, 'Dark Spooky Hallway', '/Assets/Images/darkSpookyHallway.png', 'It is pitch black. You feel your sanity draining.', 0, 1, 9, 8, -1, 7),
(7, 'Another Bedroom', '/Assets/Images/AnotherBedroom.png', 'A ruined bedroom.', 0, 0, 15, 6, -1, -1),
(8, 'Library', '/Assets/Images/Library.png', 'Books are scattered everywhere. You hear breathing.', 0, 0, -1, -1, -1, 6),
(9, 'JumpScare Frame 1', '/Assets/Images/JumpScareFrame1.png', 'AHHH!', 0, 0, 10, -1, 6, -1),
(10, 'JumpScare Frame 2', '/Assets/Images/jumpScareFrame2.png', 'AHHH!', 0, 0, 11, -1, 9, -1),
(11, 'Yellow Hallway Shadow', '/Assets/Images/yellowHallwayShadow.png', 'A sickly yellow light casts long shadows.', 0, 0, 12, 8, 10, 8),
(12, 'Scary Mirror', '/Assets/Images/scaryMirror.png', 'Your reflection doesn''t look quite right.', 0, 0, -1, -1, 11, -1),
(13, 'Dining Room', '/Assets/Images/diningRoom.png', 'A dusty dining room.', 0, 0, -1, 2, -1, -1),
(14, 'Boiler Room', '/Assets/Images/boilerRoom.png', 'It is sweltering hot in here.', 0, 0, 3, -1, -1, -1),
(15, 'Nursery', '/Assets/Images/nursery.png', 'A chillingly quiet nursery.', 0, 0, -1, -1, 7, -1);

